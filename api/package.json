{
  "name": "@secure-cloud-files/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "typecheck": "tsc --noemit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1048.0",
    "@aws-sdk/client-s3": "3.1048.0",
    "@aws-sdk/client-sts": "3.1047.0",
    "@aws-sdk/lib-dynamodb": "3.1048.0",
    "@aws-sdk/s3-request-presigner": "3.1048.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  }
}

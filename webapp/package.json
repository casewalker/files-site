{
  "name": "@secure-cloud-files/webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --cache",
    "typecheck": "tsc --noemit",
    "test:e2e": "cypress run --e2e --browser=chrome",
    "test:e2e:open": "cypress open --e2e --browser=chrome",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.3.0",
    "@secure-cloud-files/api": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jsonwebtoken": "9.0.3",
    "lucide-react": "1.25.0",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.13.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.8.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/expect": "4.1.10",
    "cypress": "15.18.1",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  }
}
